class Solution {
    public int sumOfMultiples(int n) {
        int sum=0;
        for(int i=1;i<=n;i++){
            if(i%3==0 || i%5==0 || i%7==0){
                sum+=i;
            }
        }
        return sum;
    }
}
// initialising a variable sum to zero.
// finding if each of the number from 1 to n is divisible by 3 or 5 or 7.
// returning the sum.
